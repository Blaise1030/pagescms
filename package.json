{
  "type": "module",
  "name": "pagescms",
  "description": "Community fork of Pages CMS — a GitHub-native CMS for static sites, targeting Cloudflare Workers and D1.",
  "license": "MIT",
  "author": {
    "name": "Blaise Tiong"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Blaise1030/pagescms.git"
  },
  "version": "3.0.0-alpha.1",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "setup:github-app": "node scripts/setup-github-app.mjs",
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "deploy": "vinext build && wrangler deploy",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint .",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply pagescms --remote",
    "db:migrate:local": "wrangler d1 migrations apply pagescms --local",
    "auth:generate": "npx @better-auth/cli generate --config ./lib/auth.ts --output ./auth-schema.ts --yes",
    "db:clear-cache": "npx tsx db/scripts/clear-cache.ts",
    "db:collaborators:export": "npx tsx db/scripts/collaborators/export.ts",
    "db:collaborators:import": "npx tsx db/scripts/collaborators/import.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
