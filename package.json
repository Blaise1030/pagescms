    "radix-ui": "^1.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.11.2",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.0",
