    "@uiw/codemirror-theme-xcode": "^4.25.9",
    "@uiw/react-codemirror": "^4.22.1",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.1",
